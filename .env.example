# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_API_BASE_URL: Optional backend base URL used by services/http.
# If absent or unreachable, the app falls back to local mock services.
VITE_API_BASE_URL="http://localhost:4000"

# Oracle backend connection (Sprint 2 target)
APP_ENV="dev"
DB_DIALECT="oracle"
ALLOW_ORACLE_SEED_FALLBACK="true"
ENABLE_DEMO_AUTH="true"
ORACLE_USER="APP"
ORACLE_PASSWORD="YOUR_PASSWORD"
ORACLE_CONNECT_STRING="localhost:1521/FREEPDB1"
ORACLE_POOL_MIN="1"
ORACLE_POOL_MAX="8"

# API security (P0 hardening)
JWT_SECRET="CHANGE_ME_LONG_RANDOM_SECRET"
JWT_EXPIRES_IN="1h"
AUTH_PROVIDER="local_jwt"
AUTH_PASSWORD_LOGIN_ENABLED="true"
OIDC_ISSUER=""
OIDC_AUDIENCE=""
OIDC_JWKS_URL=""
OIDC_ROLE_CLAIM="roles"
OIDC_TENANT_CLAIM="condominium_id"
OIDC_ALLOWED_ALGS="RS256"
CORS_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="120"
RATE_LIMIT_LOGIN_MAX="20"
SECURITY_AUDIT_LOG_ENABLED="true"
SECURITY_AUDIT_PERSIST_ENABLED="false"
SECURITY_AUDIT_LOG_PATH="logs/security-audit.log"
